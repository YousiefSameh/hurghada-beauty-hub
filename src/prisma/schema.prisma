generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalSettings {
  id              String   @id @default("global")
  
  phone           String
  email           String
  whatsapp        String
  address         Json
  mapEmbedUrl     String?

  facebook        String?
  instagram       String?
  tiktok          String?

  // SEO
  globalMetaTitle Json?
  globalMetaDesc  Json?

  updatedAt       DateTime @updatedAt
}

model Category {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        Json
  treatments  Treatment[]
}

model Treatment {
  id               String   @id @default(cuid())
  slug             String   @unique
  categoryId       String
  category         Category @relation(fields: [categoryId], references: [id])
  
  heroImage        String   
  cardImage        String   

  title            Json
  tagline          Json
  shortDescription Json
  howItWorks       Json
  resultsTimeline  Json

  achievements     Json
  preInstructions  Json
  postInstructions Json

  products         Product[]
  cases            BeforeAfterCase[]

  metaTitle        Json?
  metaDesc         Json?

  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Product {
  id          String    @id @default(cuid())
  treatmentId String
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  
  image       String
  name        String
  description Json
}

model BeforeAfterCase {
  id          String    @id @default(cuid())
  treatmentId String
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  
  beforeImage String
  afterImage  String
  
  label       Json
  description Json
}

model Doctor {
  id          String       @id @default(cuid())
  slug        String       @unique
  image       String
  
  name        Json
  title       Json
  quote       Json
  biography   Json

  stats       Json?

  credentials Credential[]
  expertises  Expertise[]
}

model Credential {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  icon        String
  title       Json
  description Json
}

model Expertise {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  icon        String
  title       Json
  description Json
}